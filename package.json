{
  "name": "nt-converter",
  "version": "0.1.0",
  "description": "Professional batch media converter for video editors and creatives",
  "author": "NiceTouch",
  "main": "./out/main/index.js",
  "scripts": {
    "setup:ffmpeg": "node scripts/download-ffmpeg.mjs",
    "setup:ffmpeg:all": "node scripts/download-ffmpeg.mjs --all",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps",
    "package": "electron-vite build && electron-builder --config electron-builder.yml",
    "package:win": "electron-vite build && electron-builder --win --config electron-builder.yml",
    "package:mac": "electron-vite build && electron-builder --mac --config electron-builder.yml"
  },
  "dependencies": {
    "electron-updater": "^6.3.9",
    "ogl": "^1.0.11"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@tailwindcss/vite": "^4.1.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^33.0.0",
    "electron-builder": "^26.8.2",
    "electron-vite": "^5.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.7.0"
  }
}
